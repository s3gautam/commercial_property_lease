GROQ_API_KEY=

# development or production. In production, CORS_ALLOWED_ORIGINS must be
# set or the app refuses to start.
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proplease
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google Sign-In button on web. Must match GOOGLE_CLIENT_ID above (the ID,
# not the secret, is safe to expose to the browser). Leave blank to hide
# the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Mobile only: on a physical device or simulator, localhost refers to the
# device itself, not your dev machine — use your machine's LAN IP instead
# (e.g. http://192.168.1.10:8000/api/v1).
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT_URL=http://localhost:9000

# Gates GET /api/v1/admin/seed-properties, a dev/test convenience for
# inserting 35 dummy listings. Leave blank to disable the endpoint (404s
# unconditionally). Set a random value and hit the URL with ?token=<value>
# once to seed data, then unset it again.
ADMIN_SEED_TOKEN=

DISABLE_SSL_VERIFY=false
REQUESTS_CA_BUNDLE=
SSL_CERT_FILE=

# Sends booking confirmation/reschedule emails. Leave SMTP_HOST blank to
# fall back to logging instead of sending (fine for local dev). For Gmail,
# use an App Password, not your normal password, with smtp.gmail.com:587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
